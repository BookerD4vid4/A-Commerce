# Database
DATABASE_URL=postgresql://user:password@localhost:5432/a_commerce

# JWT Secret
JWT_SECRET=your-secret-key-change-this-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# OTP Settings
DEMO_MODE=true
OTP_LENGTH=6
OTP_EXPIRY_MINUTES=5
OTP_RATE_LIMIT=3
OTP_RATE_WINDOW_MINUTES=10

# SMS Service (for production)
SMS_API_KEY=
SMS_API_URL=

# AI Services
TYPHOON_API_KEY=
TYPHOON_API_URL=https://api.opentyphoon.ai/v1
GEMINI_API_KEY=
GEMINI_EMBEDDING_MODEL=text-embedding-004

# Supabase Storage
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Payment Gateway
OMISE_PUBLIC_KEY=
OMISE_SECRET_KEY=

# CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# App Settings
APP_NAME=A-Commerce
ENVIRONMENT=development
